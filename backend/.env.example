SECRET_KEY=
DATABASE_URL=sqlite+aiosqlite:///./data/app.db
CHROMA_PERSIST_DIR=./data/chroma
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Cloudflare Access (leave blank for local dev)
CF_TEAM_DOMAIN=

# Comma-separated emails that get the admin role on first login (and on every login)
ADMIN_EMAILS=

# Local dev only: email used when CF_TEAM_DOMAIN is blank and no CF JWT is present
DEV_USER_EMAIL=dev@localhost

# Credits & agent limits
DEFAULT_USER_CREDITS=100
DEFAULT_AGENT_LIMIT=10
CREDITS_PER_ITERATION=1
